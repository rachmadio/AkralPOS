PORT=4173
HOST=127.0.0.1

# Google Sheet ID from the spreadsheet URL.
GOOGLE_SHEETS_ID=your_google_sheet_id

# Service account credentials. Share the spreadsheet with this email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Optional range overrides.
GOOGLE_SHEETS_PRODUCTS_RANGE=Products!A2:E
GOOGLE_SHEETS_ORDERS_RANGE=Orders!A2:H
GOOGLE_SHEETS_ANALYTICS_RANGE=Analytics!A2:D

# For previewing the UI before credentials are connected.
# Keep false in production so the app requires Google Sheets.
ALLOW_LOCAL_MENU_FALLBACK=false

# Optional: use Google Apps Script Web App instead of direct Google Sheets API.
# When this is set, the app uses Apps Script for Products, Orders, and Analytics.
GOOGLE_APPS_SCRIPT_URL=
